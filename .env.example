# ─────────────────────────────────────────────────────
# LinkinAgency Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# CORS — comma-separated frontend origins (required for browser + Vercel)
# Include localhost and production dashboard, e.g.:
# CORS_ORIGINS=http://localhost:3000,https://linkin-agency-dashboard.vercel.app
CORS_ORIGINS=http://localhost:3000
# Set true only if the browser must send cookies (refresh token) cross-origin
CORS_CREDENTIALS=false

# Auth
JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ADMIN_EMAIL=admin@linkinagency.local
ADMIN_INIT_PASSWORD=ChangeMe123!

# API Key (generate a random 32+ char string)
API_KEY=your_secret_api_key_here

# MongoDB
MONGODB_URI=mongodb://localhost:27017/linkinagency
# For Atlas: mongodb+srv://user:password@cluster.mongodb.net/linkinagency

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email
EMAIL_FROM=no-reply@linkinagency.local
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass

# Upload limits
MAX_FILE_SIZE_MB=10
